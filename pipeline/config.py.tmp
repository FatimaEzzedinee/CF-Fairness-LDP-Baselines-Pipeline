#   0 = age
#   1 = priors_count
#   2 = juv_fel_count
#   3 = juv_misd_count
#   4 = juv_other_count
#   5 = c_charge_degree_enc  (binary: 0=M, 1=F)
#   6 = sex_enc              (binary: 0=Male, 1=Female)
#   7 = race_enc             (binary: 0=White, 1=Black)  <-- PROTECTED

FEATURE_COLS = [
    "age",
    "priors_count",
    "juv_fel_count",
    "juv_misd_count",
    "juv_other_count",
    CHARGE_DEGREE_ENC_COL,
